  "review_cross_batch_groups": true,
  "review_repaired_groups": true,
  "review_workstream_conflicts": true,
  "review_same_conversation_only_groups": true,
  "group_reason_definitions": [
    {
      "key": "shared_message",
      "description": "事件之间存在 Python evidence_relations 明确给出的共同消息；没有共同消息计数时不得使用。",
      "evidence_relation": "message",
      "supports_semantic_merge": false
    },
    {
      "key": "shared_file",
      "description": "事件之间引用系统识别的同一个文件；不同文件即使格式、名称或用途相似也不得使用。",
      "evidence_relation": "file",
      "supports_semantic_merge": false
    },
    {
      "key": "same_conversation",
      "description": "事件来自同一天同一会话；只能用于候选发现，不能单独支持高风险多事件子组。",
      "evidence_relation": "conversation",
      "supports_semantic_merge": false
    },
    {
      "key": "same_object",
      "description": "事件处理同一个明确业务对象，不是宽泛领域或相似标题。",
      "evidence_relation": "",
      "supports_semantic_merge": true
    },
    {
      "key": "continuous_action",
      "description": "事件是同一事项的前后连续动作，能够说明动作顺序或承接关系。",
      "evidence_relation": "",
      "supports_semantic_merge": true
    },
    {
      "key": "same_deliverable_batch",
      "description": "事件涉及不同文件，但属于同一报送周期、同一提交任务或同一套交付材料；仅文件格式相同或名称相似不足以成立。",
      "evidence_relation": "",
      "supports_semantic_merge": true
    }
  ]
}
