WORKTRACE_LLM_BASE_URL=https://your-openai-compatible-endpoint.example/v1
WORKTRACE_LLM_MODEL=your-model-name
WORKTRACE_LLM_API_KEY=your-api-key
# Request timeout in seconds
WORKTRACE_LLM_TIMEOUT_SECONDS=1200
# Enable internal streaming mode
WORKTRACE_LLM_STREAM=true
# Optional: verify HTTPS certificates
# WORKTRACE_LLM_TLS_VERIFY=false
# The main flow requires the effective value to remain none; this matches the built-in default
WORKTRACE_LLM_REASONING_EFFORT=none
# Optional: random delay between online requests; 0 disables the delay
# WORKTRACE_LLM_SLEEP_MIN_SECONDS=0
# WORKTRACE_LLM_SLEEP_MAX_SECONDS=0
# Optional: retry the current collected-merge batch after recoverable model errors
# WORKTRACE_COLLECTED_MERGE_RETRYABLE_ERROR_LIMIT=1
# WORKTRACE_COLLECTED_MERGE_RETRY_DELAY_SECONDS=2
